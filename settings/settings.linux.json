{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(git -C ~/.claude *)",
      "Bash(git -C /home/jdeiv/.claude *)",
      "Bash(cd ~/.claude && git *)",
      "Bash(bash /home/jdeiv/.claude/hooks/gsd-autosync.sh)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(uv *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git pull *)"
    ],
    "deny": [
      "Bash(git push *ansible-deployment*)",
      "Bash(git pull *ansible-deployment*)",
      "Bash(git commit *ansible-deployment*)",
      "Bash(git push *ansible-larus*)",
      "Bash(git pull *ansible-larus*)",
      "Bash(git commit *ansible-larus*)",
      "Bash(git push *zabbix-server*)",
      "Bash(git pull *zabbix-server*)",
      "Bash(git commit *zabbix-server*)",
      "Bash(git push *zazu*)",
      "Bash(git pull *zazu*)",
      "Bash(git commit *zazu*)",
      "Bash(git -C *ansible* push)",
      "Bash(git -C *ansible* pull)",
      "Bash(git -C *ansible* commit *)",
      "Bash(git -C *zabbix* push)",
      "Bash(git -C *zabbix* pull)",
      "Bash(git -C *zabbix* commit *)",
      "Bash(git -C *zazu* push)",
      "Bash(git -C *zazu* pull)",
      "Bash(git -C *zazu* commit *)",
      "Bash(cd *ansible* && git push)",
      "Bash(cd *ansible* && git pull)",
      "Bash(cd *ansible* && git commit *)",
      "Bash(cd *zabbix* && git push)",
      "Bash(cd *zabbix* && git pull)",
      "Bash(cd *zabbix* && git commit *)",
      "Bash(cd *zazu* && git push)",
      "Bash(cd *zazu* && git pull)",
      "Bash(cd *zazu* && git commit *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"$HOME/.claude\" pull --no-edit 2>&1 || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/jdeiv/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/home/jdeiv/.claude/hooks/gsd-session-state.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/home/jdeiv/.claude/hooks/gsd-autosync.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/jdeiv/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/jdeiv/.claude/hooks/gsd-read-injection-scanner.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/home/jdeiv/.claude/hooks/gsd-phase-boundary.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/jdeiv/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/jdeiv/.claude/hooks/gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/jdeiv/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/home/jdeiv/.claude/hooks/gsd-validate-commit.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"/usr/bin/node\" \"/home/jdeiv/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "theme": "dark"
}
