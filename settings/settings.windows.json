{
  "model": "claude-sonnet-5",
  "bashAllowlist": [
    "git -C \"%USERPROFILE%\\.claude\" *",
    "cd \"%USERPROFILE%\\.claude\" && git *",
    "git -C C:\\Users\\deiv\\.claude *",
    "ls *",
    "ls",
    "cat *",
    "head *",
    "tail *",
    "find * -name *",
    "echo *",
    "pwd",
    "which *",
    "where *",
    "wc *",
    "dir *",
    "node *",
    "python *",
    "python3 *",
    "npx *",
    "npm *",
    "uv *"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"%USERPROFILE%\\.claude\" pull --no-edit 2>&1 || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"RUTA_NODE_WINDOWS\\node.exe\" \"C:\\Users\\deiv\\.claude\\hooks\\gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:\\Users\\deiv\\.claude\\hooks\\gsd-session-state.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"%USERPROFILE%\\.claude\" && git add -A && if ! git diff --cached --quiet 2>/dev/null; then git commit -m \"auto-sync: $(date -Iseconds)\" && git push; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"RUTA_NODE_WINDOWS\\node.exe\" \"C:\\Users\\deiv\\.claude\\hooks\\gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"RUTA_NODE_WINDOWS\\node.exe\" \"C:\\Users\\deiv\\.claude\\hooks\\gsd-read-injection-scanner.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:\\Users\\deiv\\.claude\\hooks\\gsd-phase-boundary.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"RUTA_NODE_WINDOWS\\node.exe\" \"C:\\Users\\deiv\\.claude\\hooks\\gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"RUTA_NODE_WINDOWS\\node.exe\" \"C:\\Users\\deiv\\.claude\\hooks\\gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"RUTA_NODE_WINDOWS\\node.exe\" \"C:\\Users\\deiv\\.claude\\hooks\\gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:\\Users\\deiv\\.claude\\hooks\\gsd-validate-commit.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"RUTA_NODE_WINDOWS\\node.exe\" \"C:\\Users\\deiv\\.claude\\hooks\\gsd-statusline.js\""
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "theme": "dark"
}
